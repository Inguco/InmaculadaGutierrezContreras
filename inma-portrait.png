
:root{
  --bg:#cbc2b5;
  --bg-soft:#e9ddd6;
  --panel:#efe7de;
  --text:#3d1700;
  --muted:#5b3824;
  --white:#fffaf5;
  --shadow:0 18px 40px rgba(61,23,0,.08);
  --radius:28px;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  margin:0;
  font-family: "Josefin Sans", Arial, sans-serif;
  color:var(--text);
  background:var(--bg);
}
h1,h2,h3,h4,.brand{
  font-family: Georgia, "Times New Roman", serif;
}
a{text-decoration:none;color:inherit}
img{max-width:100%;display:block}
.site-header{
  position:sticky; top:0; z-index:20;
  background:rgba(239,231,222,.92);
  backdrop-filter: blur(8px);
  border-bottom:1px solid rgba(61,23,0,.08);
}
.nav{
  width:min(1240px, calc(100% - 40px));
  margin:0 auto;
  display:flex; align-items:center; justify-content:space-between;
  padding:18px 0;
  gap:20px;
}
.brand{font-size:1.3rem; font-weight:700}
.nav-links{display:flex; gap:26px; flex-wrap:wrap}
.nav-links a{
  font-size:1.05rem;
  padding:8px 0;
  position:relative;
}
.nav-links a.active::after,.nav-links a:hover::after{
  content:""; position:absolute; left:0; right:0; bottom:-4px;
  height:2px; background:var(--text);
}
.page{
  width:min(1240px, calc(100% - 40px));
  margin:0 auto;
  padding:56px 0 72px;
}
.hero{
  display:grid;
  grid-template-columns:1.15fr .85fr;
  gap:44px;
  align-items:center;
  min-height: calc(100vh - 110px);
}
.hero-copy h1{
  font-size: clamp(3.2rem, 7vw, 6rem);
  line-height:.95;
  margin:0 0 28px;
}
.eyebrow{
  text-transform:uppercase;
  font-size:1.05rem;
  letter-spacing:.08em;
  font-weight:700;
  margin-bottom:22px;
}
.bullets{list-style:none; padding:0; margin:28px 0 36px; display:grid; gap:16px}
.bullets li{
  display:flex; gap:14px; align-items:flex-start; font-size:1.45rem;
}
.bullets li::before{
  content:"•"; font-size:2rem; line-height:1; margin-top:-3px;
}
.btn-row{display:flex; gap:18px; flex-wrap:wrap}
.btn{
  display:inline-flex; align-items:center; justify-content:center;
  padding:16px 28px; border-radius:16px; font-weight:700; font-size:1.2rem;
  border:1.5px solid var(--text);
}
.btn.primary{background:var(--text); color:var(--bg-soft)}
.btn.secondary{background:transparent}
.photo-card,.image-card{
  background:rgba(255,250,245,.35);
  border-radius:34px;
  padding:22px;
  box-shadow:var(--shadow);
}
.photo-card img,.image-card img{border-radius:24px; width:100%}
.center-intro{
  text-align:center; max-width:950px; margin:0 auto 36px;
}
.center-intro h1,.center-intro h2{margin:0 0 18px}
.center-intro h1,.center-intro h2{font-size: clamp(2.5rem, 5vw, 4.2rem)}
.center-intro p.lead{font-size:1.8rem; margin:0 0 10px}
.text-block{
  font-size:1.55rem; line-height:1.5; max-width:1140px; margin:0 auto;
}
.text-block p{margin:0 0 22px}
.media-strip{margin-bottom:38px}
.cards-4{
  display:grid; grid-template-columns:repeat(4,1fr); gap:22px; margin-top:34px;
}
.metric-card{
  background:var(--bg-soft);
  box-shadow:var(--shadow);
  padding:24px;
  min-height:210px;
}
.metric-card h3{
  margin:0 0 12px;
  font-size:2.2rem;
  font-family: "Josefin Sans", Arial, sans-serif;
  font-weight:700;
}
.metric-card p{margin:0; font-size:1.35rem; line-height:1.35; font-weight:600}
.impact-top{
  display:grid; grid-template-columns:1.2fr .8fr; gap:40px; align-items:center; margin-bottom:30px;
}
.experience-wrap{
  background:linear-gradient(180deg, #f3ebe5 0%, #eadfd8 100%);
  box-shadow:var(--shadow);
  padding:34px 26px 0;
}
.experience-grid{
  display:grid; grid-template-columns:repeat(4,1fr); gap:0;
  border-top:1px solid rgba(61,23,0,.08);
}
.exp-col{
  padding:26px 22px 34px;
  border-left:1px solid rgba(61,23,0,.08);
}
.exp-col:first-child{border-left:none}
.exp-col h3{
  margin:0 0 6px; font-size:2rem; text-transform:uppercase; font-family:"Josefin Sans", Arial,sans-serif; font-weight:700;
}
.exp-col .role{font-size:1.55rem; font-weight:700; margin:0 0 6px}
.exp-col .area{font-size:1.4rem; color:var(--muted); margin:0 0 22px}
.exp-col h4{font-size:1.55rem; margin:0 0 12px; font-family:"Josefin Sans", Arial,sans-serif}
.exp-col ul{margin:0; padding-left:24px; display:grid; gap:12px}
.exp-col li{font-size:1.35rem; line-height:1.35}
.experience-footer{
  margin-top:18px;
  background:var(--text);
  color:var(--bg-soft);
  text-align:center;
  padding:18px 20px 22px;
  font-size:2.2rem;
}
.contact-grid{
  display:grid; grid-template-columns:1.1fr .7fr; gap:46px; align-items:center;
}
.contact-panel{
  font-size:1.6rem; line-height:1.45;
}
.contact-panel h1,.contact-panel h2{font-size: clamp(2.6rem, 4.5vw, 4.1rem); margin:0 0 18px}
.contact-panel h3{font-family:"Josefin Sans", Arial,sans-serif; font-size:2rem; margin:34px 0 18px}
.contact-panel ul{padding-left:26px; margin:0; display:grid; gap:14px}
.contact-panel li{font-size:1.45rem}
.link-list a{text-decoration:underline; font-weight:700}
.section-anchor-nav{
  margin-top:18px; display:flex; gap:12px; flex-wrap:wrap; justify-content:center;
}
.pill{
  padding:10px 16px; border:1px solid rgba(61,23,0,.15); border-radius:999px; background:rgba(255,250,245,.45)
}
@media (max-width: 1100px){
  .hero,.impact-top,.contact-grid{grid-template-columns:1fr}
  .cards-4,.experience-grid{grid-template-columns:repeat(2,1fr)}
}
@media (max-width: 720px){
  .nav{flex-direction:column; align-items:flex-start}
  .nav-links{gap:18px}
  .page{padding:34px 0 50px}
  .hero-copy h1{font-size:3.4rem}
  .bullets li{font-size:1.15rem}
  .center-intro p.lead,.text-block,.contact-panel{font-size:1.2rem}
  .cards-4,.experience-grid{grid-template-columns:1fr}
  .exp-col{border-left:none; border-top:1px solid rgba(61,23,0,.08)}
  .exp-col:first-child{border-top:none}
  .experience-footer{font-size:1.6rem}
}
